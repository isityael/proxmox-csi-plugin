{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>isityael/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges",
    ":gitSignOff"
  ],
  "enabledManagers": [
    "gomod",
    "dockerfile",
    "github-actions",
    "woodpecker"
  ],
  "packageRules": [
    {
      "description": "Keep luthermonson/go-proxmox compatible with the upstream wrapper",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["github.com/luthermonson/go-proxmox"],
      "allowedVersions": "<=0.5.1"
    },
    {
      "description": "Keep the upstream go-proxmox wrapper on its compatible API",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["github.com/sergelogvinov/go-proxmox"],
      "allowedVersions": "<=0.2.0"
    },
    {
      "description": "Group Kubernetes Go modules",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["/^k8s\\.io\\//"],
      "groupName": "kubernetes go modules"
    },
    {
      "description": "Group all GitHub Actions into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": true
    },
    {
      "description": "Auto-merge patch and minor Go module updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ]
}
